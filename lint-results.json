(stat, i) => (\n              <motion.div key={i} variants={fadeInUp} className=\"flex flex-col items-center\">\n                <span className=\"text-5xl md:text-7xl font-bold text-white mb-2\">{stat.value}</span>\n                <span className=\"text-zinc-400 font-medium tracking-wide uppercase text-sm\">{stat.label}</span>\n              </motion.div>\n            ))}\n          </motion.div>\n        </div>\n      </section>\n\n      {/* CTA Section */}\n      <section className=\"py-32 px-6 bg-gradient-to-b from-black to-zinc-900 text-center flex flex-col items-center justify-center\">\n        <motion.div\n           initial=\"hidden\"\n           whileInView=\"visible\"\n           viewport={{ once: true }}\n           variants={fadeInUp}\n           className=\"max-w-3xl\"\n        >\n          <h2 className=\"text-4xl md:text-6xl font-bold text-white mb-10 leading-tight\">\n            Votre entreprise <span className=\"italic text-zinc-400\">m├⌐rite</span> un site ├á la hauteur.\n          </h2>\n          <Link \n            href=\"/contact\" \n            className=\"inline-flex items-center justify-center gap-2 px-10 py-5 bg-white text-black text-lg font-bold rounded-full hover:scale-105 transition-transform duration-300\"\n          >\n            Lancer mon projet <ArrowRight size={20} />\n          </Link>\n        </motion.div>\n      </section>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\sohan\\Documents\\apprentissage claude code\\src\\app\\prestations\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\sohan\\Documents\\apprentissage claude code\\src\\app\\projets\\page.tsx","messages":[{"ruleId":"react/no-unescaped-entities","severity":2,"message":"`'` can be escaped with `&apos;`, `&lsquo;`, `&#39;`, `&rsquo;`.","line":6,"column":104,"nodeType":"JSXText","messageId":"un